# Lictor Guardian — environment variables.
# Copy to .env.local and fill in. Never commit .env.local.

# Postgres connection. v0.1 supports a single Postgres instance.
DATABASE_URL=postgres://lictor_guardian:dev@localhost:5432/lictor_guardian

# Session signing. Generate with `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`.
SESSION_SECRET=replace_me_with_32_bytes_of_hex

# Magic-link email sending. v0.1 expects Postmark; swap in any SMTP provider.
POSTMARK_API_TOKEN=

# Public URL of this Guardian instance. Used in magic-link emails.
NEXT_PUBLIC_GUARDIAN_URL=http://localhost:3100

{
  "name": "@lictor/shield",
  "version": "0.1.0",
  "private": true,
  "description": "Lictor Shield — Chrome extension that audits AI-built sites locally.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "wasm": "cd ../core && wasm-pack build --target web --out-dir ../shield/wasm --no-default-features --features wasm",
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}

#!/bin/bash
# ai-kiosk — the user-facing session. A locked-down browser, nothing else.
#
# Boots straight into Chromium in kiosk mode on the Lictor launcher. The user
# picks a vendor (Claude / ChatGPT / Gemini) and signs in with their OWN
# account. No terminal, no file manager, no access beyond ~/projects.
set -e

# the only writable area the user ever sees
mkdir -p "$HOME/projects"

# Chromium kiosk — fresh profile each boot (ephemeral), download dir pinned to ~/projects
exec chromium \
  --kiosk \
  --no-first-run \
  --disable-translate \
  --disk-cache-dir=/tmp/cache \
  --user-data-dir=/tmp/chrome-profile \
  --start-fullscreen \
  --homepage="file:///opt/lictor/launcher.html" \
  "file:///opt/lictor/launcher.html"

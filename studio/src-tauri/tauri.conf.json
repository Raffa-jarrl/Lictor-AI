{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Lictor Studio",
  "version": "0.1.0-pre.0",
  "identifier": "ai.lictor.studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lictor Studio",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "DeveloperTool",
    "shortDescription": "Offline AI security audit for vibe-coded apps",
    "longDescription": "Lictor Studio runs Lictor's full audit locally — no telemetry, no signup, no cloud round-trip. Drop a project folder; get a plain-English report. Open source (Apache 2.0).",
    "homepage": "https://lictor.ai/studio",
    "publisher": "Lictor AI",
    "copyright": "© 2026 Lictor AI",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": ["https://lictor.ai/studio/update.json"],
      "dialog": true,
      "pubkey": ""
    }
  }
}

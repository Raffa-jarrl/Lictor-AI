{
  "name": "lictor-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Lictor AI — open-source AI security suite (Shield + Sentinel + Guardian)",
  "license": "MIT",
  "homepage": "https://lictor.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Raffa-jarrl/Lictor-AI.git"
  },
  "workspaces": [
    "shield"
  ],
  "scripts": {
    "build:core": "cargo build --release -p lictor-core",
    "build:shield": "pnpm --filter @lictor/shield build",
    "wasm": "cd core && wasm-pack build --target web --out-dir ../shield/wasm"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}

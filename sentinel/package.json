{
  "name": "@lictor/sentinel",
  "version": "0.1.0-alpha.0",
  "description": "Lictor Sentinel — wraps OpenAI / Anthropic SDKs to block prompt injection, data exfiltration, and unsafe AI behaviour.",
  "license": "Apache-2.0",
  "homepage": "https://lictor-ai.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Raffa-jarrl/Lictor-AI.git",
    "directory": "sentinel"
  },
  "keywords": [
    "ai-security",
    "prompt-injection",
    "openai",
    "anthropic",
    "guardrails",
    "llm-security"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test 'tests/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
